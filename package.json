    "@nestjs/platform-express": "^10.4.9",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/websockets": "^10.4.9",
    "@prisma/client": "^5.20.0",

# E2E test configuration for running against a remote server (VPS)
# Copy this file to .env.e2e and fill in your values.
# .env.e2e is git-ignored — never commit credentials.

# Base URL of the backend API
TEST_API_URL=https://api.yourdomain.com/api

# Existing account to log in as (must be a member of TEST_WORKSPACE_ID)
TEST_USER_EMAIL=you@yourdomain.com
TEST_USER_PASSWORD=yourpassword

# Workspace that already exists on the VPS
TEST_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# An already-CONNECTED device in that workspace.
# When set, message/broadcast tests verify real WA delivery.
TEST_DEVICE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Phone number to use as recipient in delivery tests (must be a real WA number)
TEST_RECIPIENT=628xxxxxxxxxx

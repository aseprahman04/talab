{
  "info": {
    "name": "WATether API",
    "description": "WhatsApp gateway control plane — full API collection.\n\n**Setup:**\n1. Set `baseUrl` to your backend (default: `http://localhost:3003/api`)\n2. Call **Auth / Login** or **Auth / Register** — test scripts auto-save `accessToken` and `workspaceId`\n3. All protected requests use `{{accessToken}}` via Bearer auth\n\n**Production:** set `baseUrl` to `https://talab.asia/api`\n\n**Seed values (local dev):**\n- `deviceId`: `seed-device-01`\n- `apiToken`: `wt_seeddemo000000000000000000000000000000000000000001`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3003/api", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "workspaceId", "value": "", "type": "string" },
    { "key": "deviceId", "value": "seed-device-01", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Asep Rahmanurhakim\",\n  \"email\": \"asep@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const r = pm.response.json();",
              "if (r.accessToken) {",
              "  pm.collectionVariables.set('accessToken', r.accessToken);",
              "  pm.collectionVariables.set('refreshToken', r.refreshToken);",
              "  pm.test('Register returns tokens', () => pm.expect(r.accessToken).to.be.a('string'));",
              "}"
            ]}
          }]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"aseprahmanurhakim04@gmail.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const r = pm.response.json();",
              "if (r.accessToken) {",
              "  pm.collectionVariables.set('accessToken', r.accessToken);",
              "  pm.collectionVariables.set('refreshToken', r.refreshToken);",
              "  pm.test('Login returns tokens', () => pm.expect(r.accessToken).to.be.a('string'));",
              "}"
            ]}
          }]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] },
            "description": "Revokes current session. JWT Bearer token remains valid until expiry — use Logout All for full revocation."
          }
        },
        {
          "name": "Logout All Sessions",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/logout-all", "host": ["{{baseUrl}}"], "path": ["auth", "logout-all"] },
            "description": "Revokes all active sessions for the current user."
          }
        },
        {
          "name": "List Sessions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/sessions", "host": ["{{baseUrl}}"], "path": ["auth", "sessions"] }
          }
        },
        {
          "name": "Get Access Token (from session cookie)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/access-token", "host": ["{{baseUrl}}"], "path": ["auth", "access-token"] },
            "description": "Exchange a valid session cookie (sid) for a short-lived JWT access token. Useful for SDK clients."
          }
        },
        {
          "name": "Google OAuth (browser only)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/google", "host": ["{{baseUrl}}"], "path": ["auth", "google"] },
            "description": "Open in browser — redirects to Google. On success, redirects to /console#access_token=...&refresh_token=..."
          }
        }
      ]
    },
    {
      "name": "Workspaces",
      "item": [
        {
          "name": "List Workspaces",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/workspaces", "host": ["{{baseUrl}}"], "path": ["workspaces"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const r = pm.response.json();",
              "if (Array.isArray(r) && r.length > 0) {",
              "  pm.collectionVariables.set('workspaceId', r[0].workspace.id);",
              "  pm.test('Got workspaceId', () => pm.expect(r[0].workspace.id).to.be.a('string'));",
              "}"
            ]}
          }]
        },
        {
          "name": "Create Workspace",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/workspaces", "host": ["{{baseUrl}}"], "path": ["workspaces"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ops Sales\",\n  \"slug\": \"ops-sales\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const r = pm.response.json();",
              "if (r.id) pm.collectionVariables.set('workspaceId', r.id);"
            ]}
          }]
        }
      ]
    },
    {
      "name": "Devices",
      "item": [
        {
          "name": "List Devices",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/devices?workspaceId={{workspaceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["devices"],
              "query": [{ "key": "workspaceId", "value": "{{workspaceId}}" }]
            }
          }
        },
        {
          "name": "Create Device",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/devices", "host": ["{{baseUrl}}"], "path": ["devices"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workspaceId\": \"{{workspaceId}}\",\n  \"name\": \"CS Jakarta 01\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const r = pm.response.json();",
              "if (r.id) pm.collectionVariables.set('deviceId', r.id);"
            ]}
          }]
        },
        {
          "name": "Start Pairing (QR)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/devices/{{deviceId}}/pair",
              "host": ["{{baseUrl}}"],
              "path": ["devices", "{{deviceId}}", "pair"]
            },
            "description": "Initiates WhatsApp QR pairing. Poll device status or listen to Socket.IO `device.updated` event."
          }
        },
        {
          "name": "Reconnect Device",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/devices/{{deviceId}}/reconnect",
              "host": ["{{baseUrl}}"],
              "path": ["devices", "{{deviceId}}", "reconnect"]
            }
          }
        },
        {
          "name": "Generate API Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/devices/{{deviceId}}/tokens",
              "host": ["{{baseUrl}}"],
              "path": ["devices", "{{deviceId}}", "tokens"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Production token\"\n}"
            },
            "description": "Returns `{ tokenId, token }`. The plain `token` is shown **once** — store it securely. Use as `Authorization: Bearer <token>` on message send."
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Send Message (JWT)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/messages/send", "host": ["{{baseUrl}}"], "path": ["messages", "send"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workspaceId\": \"{{workspaceId}}\",\n  \"deviceId\": \"{{deviceId}}\",\n  \"target\": \"6285795950115\",\n  \"type\": \"TEXT\",\n  \"message\": \"Halo, pesanan kamu sudah diproses!\"\n}"
            }
          }
        },
        {
          "name": "List Messages",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/messages?workspaceId={{workspaceId}}&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["messages"],
              "query": [
                { "key": "workspaceId", "value": "{{workspaceId}}" },
                { "key": "limit", "value": "50" }
              ]
            }
          }
        },
        {
          "name": "Retry Failed Message",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/messages/:id/retry",
              "host": ["{{baseUrl}}"],
              "path": ["messages", ":id", "retry"],
              "variable": [{ "key": "id", "value": "MESSAGE_ID_HERE" }]
            }
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Create Webhook",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/webhooks", "host": ["{{baseUrl}}"], "path": ["webhooks"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workspaceId\": \"{{workspaceId}}\",\n  \"name\": \"Order Notifications\",\n  \"url\": \"https://api.example.com/webhooks/watether\",\n  \"secret\": \"supersecretkey123\",\n  \"isActive\": true\n}"
            }
          }
        },
        {
          "name": "List Webhooks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/webhooks?workspaceId={{workspaceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["webhooks"],
              "query": [{ "key": "workspaceId", "value": "{{workspaceId}}" }]
            }
          }
        },
        {
          "name": "Send Test Event",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/webhooks/:id/test",
              "host": ["{{baseUrl}}"],
              "path": ["webhooks", ":id", "test"],
              "variable": [{ "key": "id", "value": "WEBHOOK_ID_HERE" }]
            }
          }
        },
        {
          "name": "Get Webhook Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/webhooks/:id/logs?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["webhooks", ":id", "logs"],
              "query": [{ "key": "limit", "value": "20" }],
              "variable": [{ "key": "id", "value": "WEBHOOK_ID_HERE" }]
            }
          }
        }
      ]
    },
    {
      "name": "Broadcasts",
      "item": [
        {
          "name": "Create Broadcast",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/broadcasts", "host": ["{{baseUrl}}"], "path": ["broadcasts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workspaceId\": \"{{workspaceId}}\",\n  \"deviceId\": \"{{deviceId}}\",\n  \"name\": \"Promo Ramadan 2025\",\n  \"messageTemplate\": \"Halo {name}! Ada promo spesial untuk kamu hari ini.\",\n  \"recipients\": [\"6285795950115\", \"628579590115\"]\n}"
            }
          }
        },
        {
          "name": "Start Broadcast",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/broadcasts/:id/start",
              "host": ["{{baseUrl}}"],
              "path": ["broadcasts", ":id", "start"],
              "variable": [{ "key": "id", "value": "BROADCAST_ID_HERE" }]
            }
          }
        },
        {
          "name": "List Broadcasts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/broadcasts?workspaceId={{workspaceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["broadcasts"],
              "query": [{ "key": "workspaceId", "value": "{{workspaceId}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Auto Replies",
      "item": [
        {
          "name": "Create Auto Reply Rule (Static Response)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/auto-replies", "host": ["{{baseUrl}}"], "path": ["auto-replies"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workspaceId\": \"{{workspaceId}}\",\n  \"deviceId\": \"{{deviceId}}\",\n  \"name\": \"Cek Status Order\",\n  \"matchType\": \"contains\",\n  \"keyword\": \"cek pesanan\",\n  \"response\": \"Halo! Silakan kirim nomor order kamu ya.\",\n  \"priority\": 10,\n  \"isEnabled\": true\n}"
            },
            "description": "Balas dengan teks statis. Gunakan `response` untuk balasan langsung tanpa integrasi eksternal."
          }
        },
        {
          "name": "Create Auto Reply Rule (Webhook / Dynamic Response)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/auto-replies", "host": ["{{baseUrl}}"], "path": ["auto-replies"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workspaceId\": \"{{workspaceId}}\",\n  \"deviceId\": \"{{deviceId}}\",\n  \"name\": \"Topup Saldo\",\n  \"matchType\": \"exact\",\n  \"keyword\": \"topup\",\n  \"webhookUrl\": \"https://esekolah.com/api/wa/handler\",\n  \"priority\": 20,\n  \"isEnabled\": true\n}"
            },
            "description": "Saat keyword cocok, WATether POST ke `webhookUrl` kamu dengan body:\n```json\n{\n  \"sender\": \"628123456789\",\n  \"keyword\": \"topup\",\n  \"message\": \"topup\",\n  \"workspaceId\": \"...\",\n  \"deviceId\": \"...\"\n}\n```\nEndpoint kamu harus mengembalikan:\n```json\n{ \"reply\": \"Halo Bu Sari! Topup via: https://pay.esekolah.com/...\" }\n```\nJika endpoint tidak merespons dalam 10 detik atau tidak ada field `reply`, balasan diabaikan.\n\n**Catatan:** Sertakan `webhookUrl` ATAU `response`, tidak keduanya."
          }
        },
        {
          "name": "List Auto Reply Rules",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/auto-replies?workspaceId={{workspaceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["auto-replies"],
              "query": [{ "key": "workspaceId", "value": "{{workspaceId}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Subscriptions",
      "item": [
        {
          "name": "List Plans",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/subscriptions/plans", "host": ["{{baseUrl}}"], "path": ["subscriptions", "plans"] },
            "description": "Public — no auth required. Returns free, bisnis, and tim plans with pricing and limits."
          }
        },
        {
          "name": "Get Workspace Subscription",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/subscriptions/{{workspaceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["subscriptions", "{{workspaceId}}"]
            }
          }
        },
        {
          "name": "Create Checkout URL",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/subscriptions/checkout", "host": ["{{baseUrl}}"], "path": ["subscriptions", "checkout"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workspaceId\": \"{{workspaceId}}\",\n  \"planCode\": \"bisnis\"\n}"
            },
            "description": "Returns `{ url }` — redirect user to this LemonSqueezy checkout URL. After payment, user is redirected back to /console?billing=1."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const r = pm.response.json();",
              "pm.test('Returns checkout URL', () => {",
              "  pm.expect(r.url).to.include('lemonsqueezy.com');",
              "});"
            ]}
          }]
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] },
            "description": "Public — returns service health status."
          }
        }
      ]
    }
  ]
}
